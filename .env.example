# Phase 2 (Postgres):
POSTGRES_USER=marketinghub
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=marketinghub

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/marketinghub
SPRING_DATASOURCE_USERNAME=marketinghub
SPRING_DATASOURCE_PASSWORD=change-me-locally

# Phase 3 (Auth):
# Generate with: openssl rand -base64 48     (must be >= 32 chars)
JWT_SECRET=please-generate-a-32-plus-char-secret-here

# Phase 4 (Multi-tenancy):
# Login identifier for the bootstrapped platform admin (username, not email).
PLATFORM_ADMIN_USERNAME=admin
PLATFORM_ADMIN_PASSWORD=admin

# Seed two demo tenants (Acme, Beta) with login accounts + ~2000 customers each on a fresh DB.
# Set to false if you don't want the sample data. Re-runs are no-ops (idempotent).
DEMO_SEED_ENABLED=true

# Phase 9 (Tenant-secret encryption — WhatsApp tokens etc.):
# 32 random bytes, base64-encoded. Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=please-generate-32-random-bytes-and-base64-encode-them=

# Phase 13 (Blast worker — RabbitMQ + Redis + mock toggle):
RABBITMQ_USER=marketinghub
RABBITMQ_PASSWORD=change-me-locally
# WHATSAPP_MOCK=true short-circuits WhatsAppApiClient.sendText to return a fake
# wamid instead of calling Meta. Flip to false once real WhatsApp creds are saved
# via the Phase 9 UI.
WHATSAPP_MOCK=false

# Phase 14 (Inbound webhooks):
# Pick any random string for the verify token and paste the same value into
# Meta's webhook configuration UI; the GET handshake compares the two.
WHATSAPP_VERIFY_TOKEN=marketinghub-acme-prod-2026-verify-xyz

# The Meta App secret. Meta signs each webhook body with HMAC-SHA256(app_secret, body).
# Found at: developers.facebook.com/apps/<appId>/settings/basic
WHATSAPP_APP_SECRET=318c26b4b8b99d072a0891b0f11c1703

# Phase 16 (AI chatbot replies):
# Default OPENAI_MOCK=true uses a deterministic canned reply (handoff triggers on
# "human"/"agent"/"speak to someone" keywords) so local dev doesn't need an API key.
# Flip to false + paste a real key to call OpenAI for real.
OPENAI_MOCK=true
# Spring AI's OpenAI auto-config validates this is non-blank at startup even when
# nothing actually calls OpenAI. Leave the placeholder while OPENAI_MOCK=true; paste
# your real key here (and flip OPENAI_MOCK=false) when ready for live calls.
OPENAI_API_KEY=sk-mock-not-called-in-mock-mode
OPENAI_CHAT_MODEL=gpt-4o-mini

# Local dev tunnel for Meta WhatsApp webhooks.
# Public but not secret; keep the ngrok auth token in ngrok's own config.
NGROK_STATIC_URL=https://your-static-domain.ngrok-free.dev
